# Seamless-RAG Configuration
# Copy to .env and fill in your values

# ── MariaDB ──────────────────────────────
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_USER=root
MARIADB_PASSWORD=seamless
MARIADB_DATABASE=seamless_rag

# ── Embedding ────────────────────────────
# Default: local sentence-transformers (no API key needed for judges)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384
#
# Gemini Embedding (latest, strongest — recommended for dev/demo)
# EMBEDDING_PROVIDER=gemini
# EMBEDDING_MODEL=gemini-embedding-exp-03-07
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_API_KEY=your-google-api-key
#
# OpenAI Embedding
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-large
# EMBEDDING_DIMENSIONS=768
# EMBEDDING_API_KEY=your-openai-api-key

# ── LLM Provider ─────────────────────────
# Options: ollama, gemini, openai, groq
#
# Ollama (default — local, no API key)
LLM_PROVIDER=ollama
LLM_MODEL=qwen3:8b
#
# Gemini (recommended for dev/demo — fast, strong, free tier)
# LLM_PROVIDER=gemini
# LLM_MODEL=gemini-2.5-flash
# LLM_API_KEY=your-google-api-key
#
# OpenAI (latest strongest model)
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# LLM_API_KEY=your-openai-api-key
# OPENAI_API_KEY=your-openai-api-key
#
# Groq (free tier: llama-3.3-70b-versatile, 300+ tok/s)
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=your-groq-api-key
# LLM_BASE_URL=https://api.groq.com/openai/v1

# ── Watch Mode ───────────────────────────
WATCH_INTERVAL=2.0
WATCH_BATCH_SIZE=64
